<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- ============================================================
         Sunshine AI Platform — 统一日志配置
         日志目录: <项目根>/logs/
         每个模块通过 spring.application.name 区分文件名
         控制台: 带模块名高亮
         文件:   按大小+时间滚动，保留 30 天，总量上限 1GB
         ERROR:  单独输出错误日志
    ============================================================ -->

    <!-- Spring 属性注入：模块名
         注意：logging.level.* 由 Spring Boot LoggingSystem 自动接管，
         不在此声明；application.yml 中的 logging.level 配置会自动覆盖
         下面 <root> 和 <logger> 的 level 值。 -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="unknown-app"/>

    <!-- ==================== 控制台 ==================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan([%15.15thread]) %magenta([%-20.20logger{0}]) - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 全量日志文件 ==================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>./logs/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>./logs/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 错误日志单独输出 ==================== -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>./logs/${APP_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>./logs/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 级别控制 ====================
         默认值：root=INFO，com.sunshine=DEBUG。
         application.yml 中 logging.level.* 会被 Spring Boot
         LoggingSystem 接管，自动覆盖这里的默认值。 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

    <!-- Sunshine 业务包（application.yml 可覆盖） -->
    <logger name="com.sunshine" level="DEBUG"/>

    <!-- 框架噪音抑制 -->
    <logger name="io.milvus" level="WARN"/>
    <logger name="org.springframework.cloud.gateway" level="INFO"/>
    <logger name="com.alibaba.nacos" level="INFO"/>

</configuration>
