{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (strategy) (rate(rag_search_requests_total{status=\"success\"}[5m]))",
          "legendFormat": "{{strategy}}",
          "refId": "A"
        }
      ],
      "title": "检索 QPS（按策略）",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, strategy) (rate(rag_search_duration_seconds_bucket{status=\"success\"}[5m])))",
          "legendFormat": "p95 {{strategy}}",
          "refId": "A"
        }
      ],
      "title": "检索 P95 延迟",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(rag_empty_total[5m])) / sum(rate(rag_search_requests_total{status=\"success\"}[5m]))",
          "legendFormat": "empty rate",
          "refId": "A"
        }
      ],
      "title": "空召回率",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rag_rerank_duration_seconds_bucket{status=\"success\"}[5m])))",
          "legendFormat": "rerank p95",
          "refId": "A"
        }
      ],
      "title": "Rerank P95 耗时",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (strategy) (rate(rag_search_hits_sum[5m])) / sum by (strategy) (rate(rag_search_hits_count[5m]))",
          "legendFormat": "avg hits {{strategy}}",
          "refId": "A"
        }
      ],
      "title": "平均命中条数",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(rag_search_errors_total[5m])) / sum(rate(rag_search_requests_total[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(rag_vector_anchor_empty_total[5m]))",
          "legendFormat": "vector anchor empty/s",
          "refId": "B"
        }
      ],
      "title": "错误率 & 向量锚点拦截",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["sunshine", "rag"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Sunshine RAG 检索",
  "uid": "sunshine-rag",
  "version": 1
}
