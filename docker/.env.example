# 网络配置
SUBNET=10.10.0.0/16

# Docker 宿主机 IP（供微服务连接 middleware 时使用，默认 localhost）
DOCKER_HOST_IP=ecs4c8g

# MySQL
MYSQL_ROOT_PASSWORD=root123
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Nacos（主端口 8848，gRPC 9848）
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# RocketMQ
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_BROKER_PORT=10911
ROCKETMQ_BROKER_VIP_PORT=10909
ROCKETMQ_PROXY_PORT=8080
ROCKETMQ_PROXY_GRPC_PORT=8081
ROCKETMQ_DASHBOARD_PORT=8082

# Elasticsearch（固定 IP，避免容器内 Netty DNS 解析超时）
ES01_IP=10.10.5.21
ES02_IP=10.10.5.22
ES03_IP=10.10.5.23
ES01_PORT=9200
ES02_PORT=9201
ES03_PORT=9202

# Kibana
KIBANA_PORT=5601

# MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# XXL-Job
XXL_JOB_PORT=8083

# Sentinel
SENTINEL_PORT=8858
SENTINEL_USERNAME=sentinel
SENTINEL_PASSWORD=sentinel123

# SkyWalking
SKYWALKING_GRPC_PORT=11800
SKYWALKING_HTTP_PORT=12800
SKYWALKING_UI_PORT=8084

# Seata（仅宿主机映射端口；容器内 TC 8091、控制台 HTTP 7091）
SEATA_PORT=8091
SEATA_CONSOLE_PORT=7091

# Canal（Server 数据口；Admin Web 控制台）
CANAL_PORT=11111
CANAL_ADMIN_PORT=8089
CANAL_ADMIN_PASSWORD=123456

# Prometheus + Grafana（监控面板）
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# Milvus
MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091
